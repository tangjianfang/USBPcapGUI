{
  "name": "usbpcapgui",
  "version": "1.0.0",
  "description": "USBPcapGUI Web UI - browser-based USB protocol analyzer interface",
  "main": "server.js",
  "bin": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js --dev",
    "test": "node --test test/",
    "bundle": "npx @yao-pkg/pkg . --targets node20-win-x64 --output ../dist/gui-server.exe"
  },
  "dependencies": {
    "express": "^4.21.0",
    "ws": "^8.18.0",
    "open": "^10.1.0"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^5.12.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "pkg": {
    "targets": [
      "node20-win-x64"
    ],
    "assets": [
      "public/**/*"
    ],
    "scripts": [
      "server.js",
      "core-bridge.js"
    ],
    "outputPath": "../dist"
  },
  "private": true
}